string = input()

# 1. Вывести третий символ этой строки
print(string[2])

# 2. Вывести предпоследний символ этой строки
print(string[-2])

# 3. Вывести первые пять символов этой строки
print(string[:5])

# 4. Вывести всю строку, кроме последних двух символов
print(string[:-2])

# 5. Вывести все символы с четными индексами
print(string[::2])

# 6. Вывести все символы с нечетными индексами (счет с 1)
print(string[1::2])


# 7. Вывести все символы строки в обратном порядке
print(string[::-1])

# 8. Вывести все символы строки через один в обратном порядке
print(string[::-2])

# 9. Вывести длину данной строки
print(len(string))
